{
  // ─── Workbench & UI ──────────────────────────────────────────────────────────
  "workbench.startupEditor": "newUntitledFile",
  "workbench.editor.enablePreview": true,
  "workbench.colorTheme": "Dracula Theme",
  "workbench.iconTheme": "symbols",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  "workbench.colorCustomizations": {},
  "window.commandCenter": false,
  "window.zoomLevel": 1,
  "symbols.hidesExplorerArrows": false,
  "symbols.files.associations": {
    "*.module.ts": "nest",
    "*.service.ts": "nest-service",
    "*.controller.ts": "nest-controller",
    "*.guard.ts": "typescript",
    "*.spec.ts": "jest",
    "vitest.config.e2e.ts": "vite",
    ".env.sample": "gear",
    ".env.*": "gear",
    ".env.example": "gear"
  },

  // ─── Editor — Aparência ───────────────────────────────────────────────────────
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.4,
  "editor.fontLigatures": true,
  "editor.rulers": [90, 120],
  "editor.minimap.enabled": true,
  "editor.scrollbar.horizontal": "hidden",
  "editor.renderLineHighlight": "gutter",
  "editor.renderWhitespace": "all",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.tokenColorCustomizations": {
    "[*Light*]": {
      "textMateRules": [
        {
          "scope": "ref.matchtext",
          "settings": { "foreground": "#000" }
        }
      ]
    }
  },

  // ─── Editor — Comportamento ───────────────────────────────────────────────────
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {},
  "editor.linkedEditing": true,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.accessibilitySupport": "off",
  "editor.parameterHints.enabled": false,
  "editor.snippets.codeActions.enabled": false,
  "editor.suggest.showProperties": true,

  // ─── Terminal ─────────────────────────────────────────────────────────────────
  "terminal.external.osxExec": "warp.app",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.stickyScroll.enabled": false,

  // ─── Explorer & Arquivos ──────────────────────────────────────────────────────
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": ".eslint*, prettier*, .prettier*, tsconfig*, vite*, pnpm-lock*, bun.lockb, nest*, package-lock.json, .editorconfig",
    "tailwind.config*": "tailwind.config*, postcss.config*",
    ".env": ".env*"
  },
  "files.associations": {
    "*.js": "javascriptreact",
    "*.twig": "twig",
    "*.html": "html"
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/dist": true,
    "**/build": true
  },

  // ─── Git ──────────────────────────────────────────────────────────────────────
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "git.ignoreMissingGitWarning": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "gitlens.hovers.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.launchpad.includedOrganizations": ["totalpass"],
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "githubPullRequests.pullBranch": "never",
  "githubPullRequests.terminalLinksHandler": "github",

  // ─── ESLint & Prettier ────────────────────────────────────────────────────────
  "eslint.enable": true,
  "eslint.run": "onSave",
  "eslint.format.enable": true,
  "eslint.useESLintClass": true,
  "eslint.lintTask.enable": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "prettier.printWidth": 100,
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,

  // ─── TypeScript / JavaScript ──────────────────────────────────────────────────
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.renameMatchingJsxTags": true,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "javascript.updateImportsOnFileMove.enabled": "prompt",
  "javascript.preferences.renameMatchingJsxTags": true,
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
  "emmet.syntaxProfiles": {
    "javascript": "jsx"
  },
  "emmet.includeLanguages": {
    "twig": "html",
    "javascript": "javascriptreact",
    "erb": "html"
  },

  // ─── Formatters por linguagem ─────────────────────────────────────────────────
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[handlebars]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[svg]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[twig]": {
    "editor.defaultFormatter": "mblode.twig-language-2"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[river]": {
    "editor.defaultFormatter": "Grafana.grafana-alloy"
  },
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit",
      "source.unusedImports": "explicit",
      "source.removeUnusedImports": "explicit"
    }
  },
  "[ruby]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [120],
    "editor.semanticHighlighting.enabled": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true
  },
  "[erb]": {
    "editor.defaultFormatter": "aliariff.vscode-erb-beautify",
    "editor.formatOnSave": true
  },

  // ─── PHP / Intelephense ───────────────────────────────────────────────────────
  "intelephense.stubs": [
    "apache", "bcmath", "bz2", "calendar", "com_dotnet", "Core", "ctype",
    "curl", "date", "dba", "dom", "enchant", "exif", "FFI", "fileinfo",
    "filter", "fpm", "ftp", "gd", "gettext", "gmp", "hash", "iconv", "imap",
    "intl", "json", "ldap", "libxml", "mbstring", "meta", "mysqli", "oci8",
    "odbc", "openssl", "pcntl", "pcre", "PDO", "pdo_ibm", "pdo_mysql",
    "pdo_pgsql", "pdo_sqlite", "pgsql", "Phar", "posix", "pspell", "random",
    "readline", "Reflection", "session", "shmop", "SimpleXML", "snmp", "soap",
    "sockets", "sodium", "SPL", "sqlite3", "standard", "superglobals",
    "sysvmsg", "sysvsem", "sysvshm", "tidy", "tokenizer", "xml", "xmlreader",
    "xmlrpc", "xmlwriter", "xsl", "Zend OPcache", "zip", "zlib", "imagick"
  ],

  // ─── Ruby LSP ─────────────────────────────────────────────────────────────────
  "rubyLsp.rubyVersionManager": {
    "identifier": "rvm"
  },
  "rubyLsp.featureFlags": {
    "all": true
  },
  "rubyLsp.addonSettings": {
    "Ruby LSP RSpec": {
      "rspecCommand": "bin/rspec"
    }
  },
  "rubyLsp.useBundlerCompose": false,
  "rubyLsp.formatter": "rubocop",
  "rubyLsp.indexing": {},
  "solargraph.diagnostics": true,
  "solargraph.formatting": true,
  "solargraph.hover": true,
  "solargraph.references": true,
  "solargraph.rename": true,
  "solargraph.symbols": true,
  "solargraph.completion": true,

  // ─── Python ───────────────────────────────────────────────────────────────────
  "python.analysis.indexing": false,
  "python.analysis.logLevel": "Trace",
  "python.analysis.autoImportCompletions": true,

  // ─── Dart / Flutter ───────────────────────────────────────────────────────────
  "dart.flutterSdkPath": "~/Downloads/flutter",
  "dart.enableSdkFormatter": true,
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,

  // ─── Misc extensões ───────────────────────────────────────────────────────────
  "css.validate": true,
  "scss.validate": false,
  "notebook.formatOnSave.enabled": false,
  "svg.preview.mode": "img",
  "tailwind-fold.autoFold": false,
  "tailwind-fold.unfoldedTextOpacity": 0.3,
  "evenBetterToml.formatter.trailingNewline": false,
  "markdown.preview.openMarkdownLinks": "inPreview",
  "prisma.showPrismaDataPlatformNotification": false,
  "redhat.telemetry.enabled": false,
  "docker.extension.enableComposeLanguageServer": false,
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "dev.containers.dockerPath": "/opt/homebrew/bin/docker",
  "debug.javascript.autoAttachFilter": "disabled",
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": false,

  // ─── Todo Tree ────────────────────────────────────────────────────────────────
  "todo-tree.highlights.defaultHighlight": {
    "icon": "alert",
    "type": "text",
    "opacity": 50
  },
  "todo-tree.filtering.excludeGlobs": ["**/node_modules/**"],
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "foreground": "#222",
      "background": "#ff8800",
      "iconColour": "#ff8800",
      "type": "tag-and-comment",
      "gutterIcon": true
    },
    "FIXME": {
      "foreground": "#f00",
      "background": "#fff",
      "iconColour": "#f00",
      "gutterIcon": true
    }
  },

  // ─── Copilot ──────────────────────────────────────────────────────────────────
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": false,

  // ─── Datadog ──────────────────────────────────────────────────────────────────
  "datadog.connection.oauth.setup.organizationId": "a53df4dc-8811-11ec-bfec-da7ad0900002",
  "datadog.telemetry.setup.enableTelemetry": "enabled",
  "datadog.connection.notification.suppressSignInNotification": true,
  "datadog.staticAnalysis.notification.suppressOnboarding": true,

  // ─── Acessibilidade ───────────────────────────────────────────────────────────
  "accessibility.voice.speechLanguage": "pt-BR",
  "accessibility.signals.lineHasError": { "sound": "off" },
  "accessibility.signals.lineHasFoldedArea": { "sound": "off" },
  "accessibility.signals.lineHasBreakpoint": { "sound": "off" },
  "accessibility.signals.lineHasInlineSuggestion": { "sound": "off" },
  "accessibility.signals.onDebugBreak": { "sound": "off" },
  "accessibility.signals.noInlayHints": { "sound": "off" },

  // ─── Sync & Updates ───────────────────────────────────────────────────────────
  "update.mode": "manual",
  "sync.gist": "9ad50d94dc00c2d651eccf2cf3e7fec7",
  "settingsSync.ignoredSettings": [
    "notes.notesLocation",
    "-window.zoomLevel"
  ],

  // ─── Claude Code ─────────────────────────────────────────────────────────────
  "claudeCode.preferredLocation": "sidebar",
  "chat.agent.maxRequests": 50,
  "chat.viewSessions.orientation": "stacked",

  // ─── Notes ───────────────────────────────────────────────────────────────────
  // ATENÇÃO chezmoi: notes.notesLocation não suporta ~ — use template se o path mudar entre máquinas
  "notes.notesLocation": "/Users/nathan/www/notes"
}
